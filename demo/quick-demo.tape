Output demo/quick-demo.gif
Set FontSize 24
Set Width 1200
Set Height 600
Set Padding 40

# Start Interactive Shell
Type "./golem"
Sleep 500ms
Enter
Sleep 2s

# Type out the command cleanly
Type "move all .txt files from demo/fixtures/projects to demo/fixtures/finance"
Sleep 500ms
Enter

# Let the user see the plan processing
Sleep 2s

# Confirm the move operation
Type "y"
Sleep 500ms
Enter

# Let the user see the final success message
Sleep 3s
