# Golem Environment Variables Configuration
# Copy this file to .env and adjust the values as needed if you prefer using environment variables over the .golem.yaml config file.

# The root sandbox directory for Golem to operate within. Defaults to current working directory.
# DIR=/path/to/sandbox

# The Ollama model to use for generating execution plans.
# MODEL=qwen2.5-coder:1.5b

# The endpoint for the Ollama instance.
# ENDPOINT=http://localhost:11434

# Set to true to allow Golem to process hidden files and directories (those starting with a dot).
# INCLUDE_HIDDEN=false

# Set to true to bypass the execution confirmation prompt. Use with caution!
# AUTO_CONFIRM=false

# The number of times to retry a failed LLM generation.
# MAX_RETRIES=3

# Comma-separated list of directories to exclude from processing.
# EXCLUDE_DIRS=node_modules,.git,build,dist

# Comma-separated list of folders that Golem is explicitly allowed to delete.
# DELETABLE_FOLDERS=temp,cache
